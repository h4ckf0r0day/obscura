{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/install.js\"",
            "async": false
          }
        ],
        "description": "Install obscura-mcp binary if missing, register MCP server and seed skills/agents"
      }
    ]
  }
}
