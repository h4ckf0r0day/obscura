From d93eb26255153325f161b7a821d8d3156823c26a Mon Sep 17 00:00:00 2001
From: charlesmamane26-sketch <charlesmamane1826@gmail.com>
Date: Wed, 10 Jun 2026 14:13:16 +0200
Subject: [PATCH 05/11] fix(js): remove Deno.core.ops from the page realm

OPS-01: bootstrap ran in the same V8 realm where deno_core exposes Deno.core.ops, and never removed it, so any page <script> could call every privileged op directly (op_fetch_url/op_set_cookie/...), bypassing every JS-layer guard (the master key behind OPS-02/04). Wrap bootstrap in an IIFE so its internals no longer leak via the shared global lexical scope; bridges call a private op table captured at runtime in __obscura_init; narrow the page-reachable Deno.core.ops to the two non-sensitive ops CDP-injected JS needs (op_dom, op_binding_called) and drop the rest.

Co-Authored-By: Claude Opus 4.8 <noreply@anthropic.com>

diff --git a/crates/obscura-js/js/bootstrap.js b/crates/obscura-js/js/bootstrap.js
index 2904431..12d75dd 100644
--- a/crates/obscura-js/js/bootstrap.js
+++ b/crates/obscura-js/js/bootstrap.js
@@ -1,5 +1,18 @@
 "use strict";
 
+// Bootstrap runs inside this IIFE so its internals — the op bridges, helper
+// functions, and the captured op table below — are NOT visible on the global
+// lexical scope. Page <script> bodies execute in the SAME V8 realm, so any
+// top-level `const`/`let`/`function` here would otherwise be readable by name
+// from hostile page JS (audit OPS-01). Page-facing API is published via
+// globalThis.* and is unaffected.
+(() => {
+
+// deno_core's op table, captured privately at RUNTIME in __obscura_init (ops are
+// not registered at snapshot-build time, so this must not capture at top level).
+// Every op bridge in this file calls through `__ops`; page JS cannot name it.
+let __ops = null;
+
 globalThis.__obscura_errors = [];
 
 globalThis.addEventListener = globalThis.addEventListener || function(){};
@@ -25,7 +38,7 @@ globalThis.dispatchEvent = function(event) {
   return !event.defaultPrevented;
 };
 
-const _dom = (cmd, a1, a2) => Deno.core.ops.op_dom(cmd, String(a1 ?? ""), String(a2 ?? ""));
+const _dom = (cmd, a1, a2) => __ops.op_dom(cmd, String(a1 ?? ""), String(a2 ?? ""));
 
