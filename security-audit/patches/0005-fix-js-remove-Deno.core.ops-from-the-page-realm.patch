-          const raw = await Deno.core.ops.op_fetch_url(task.url, "GET", "{}", "", task.pageOrigin, "no-cors");
+          const raw = await __ops.op_fetch_url(task.url, "GET", "{}", "", task.pageOrigin, "no-cors");
           const parsed = JSON.parse(raw);
